# Copy this file to `.env` and fill in real values.
# `.env` is gitignored - never commit it.
#
# All of these are OPTIONAL: if a value is missing here and in the environment,
# the notebook prompts you for it interactively (the API hash, 2FA password and
# login code are typed in hidden). Leaving everything blank just disables the
# live-collection cells - the offline analysis still runs.

# From https://my.telegram.org/apps  (App api_id / App api_hash)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your phone in international format, e.g. +972541234567 (no spaces / dashes)
TELEGRAM_PHONE=

# 64-char random hex. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
HASH_SALT=
