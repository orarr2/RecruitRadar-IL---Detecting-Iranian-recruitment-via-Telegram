# Copy to agent/.env and adjust. Everything here is OPTIONAL - the defaults
# below are what the notebook uses when a value is missing.
# The project-root .env (HASH_SALT, Telegram credentials) is loaded first.

# Which provider drives LF3. Local = "ollama" (default, free, no key needed).
# Cloud = "groq" (free tier, needs GROQ_API_KEY; used by the GitHub Actions
# workflow so scheduled cloud runs get real LLM scoring).
LLM_PROVIDER=ollama

# Local LLM endpoint (Ollama). If unreachable, the LLM labeler abstains and
# the rest of the pipeline runs normally.
OLLAMA_HOST=http://localhost:11434

# Which local model classifies the mid-band messages.
#   ollama pull llama3.2:3b     (fast, ~2 GB)
#   ollama pull qwen2.5:7b      (better multilingual, ~4.7 GB)
OLLAMA_MODEL=llama3.2:3b

# Groq settings - only used when LLM_PROVIDER=groq.
# Get a free API key at https://console.groq.com/keys (Google login is fine).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Budget ceiling per run (N5). The layer-2 pass is skipped entirely if the
# projected number of uncached calls exceeds this.
MAX_LLM_CALLS=300

# Drop messages older than this many days (0 disables cleanup).
RETENTION_DAYS=90

# Recorded on every verdict line in data/verdicts.jsonl.
ANALYST_ID=analyst

# ── Telegram control bot (agent/telegram_bot.py) ──
# Create a bot: open Telegram, message @BotFather, send /newbot, follow the
# prompts, and copy the token it gives you into TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=

# Your own Telegram chat id, so only you can drive the bot. Leave blank the
# first time: run the bot, send it /start, and it replies with your id - then
# paste it here and restart.
BOT_OWNER_ID=
